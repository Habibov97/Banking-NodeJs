<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Document</title>
  </head>
  <body>
    <table width="500" cellpadding="0" cellspacing="0" style="background:#ffffff; padding:40px; border-radius:8px;">    
      <tr>
        <td align="center">
          <h2 style="margin-bottom:10px;">Confirm Your Transaction</h2>
          <p style="color:#555; font-size:14px; line-height:1.5;">
            We received a request to complete a transaction from your account.
            Please confirm this transaction by clicking the button below.
          </p>
        </td>
      </tr>

      <tr>
        <td align="center" style="padding:30px 0;">
          <a href="{{confirmUrl}}" 
             style="background:#4f46e5; color:#ffffff; padding:12px 24px; text-decoration:none; border-radius:6px; font-size:14px; font-weight:bold;">
            Confirm Transaction
          </a>
        </td>
      </tr>

      <tr>
        <td align="center">
          <p style="color:#888; font-size:12px;">
            If you did not request this transaction, you can safely ignore this email.
          </p>
        </td>
      </tr>

    </table>

  </td>
</tr>
</body>
</html>